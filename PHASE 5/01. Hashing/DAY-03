🔹 Generics kya hota hai?
- Tum ek hi code ko different data types ke sath use kar sakte ho.
- Code ko type-safe aur reusable banana.
- Compile time pe type checking ho jaati hai (runtime error kam hote hain).
Without Generics (Problem 😓) :
             List list = new ArrayList();
             list.add("Hello");
             list.add(10); // allowed ❌ (mixed type)
             String s = (String) list.get(1); // Runtime error 💥
With Generics (Solution 😍) :
             List<String> list = new ArrayList<>();
             list.add("Hello");
             // list.add(10); ❌ compile time error
             String s = list.get(0); // no casting needed ✅
Generics ka Syntax :
class Box<T> {
    T value;

    void set(T value) {
        this.value = value;
    }

    T get() {
        return value;
    }
}

💥 USE :
Box<Integer> b1 = new Box<>();
b1.set(10);

Box<String> b2 = new Box<>();
b2.set("Hello");













                                                                   DESIGNING HASHMAP FROM SCRATCH (Seperate Chaining)
                                                                   ---------------------------------------------------


import java.util.LinkedList;
import java.util.Objects;

public class MyHashMap<K,V>{

    class Node{
        K key;
        V value;
        Node(K key,V value){
            this.key=key;
            this.value=value;
        }

        @Override
        public String toString() {
            return key+" : "+value;
        }
    }
    private LinkedList<Node> [] hashTable ;
    private int elements;
    private int tableSize;
    private double threshold;


    MyHashMap(){
        this.elements=0;
        this.tableSize=16;
        this.threshold=0.75;
        hashTable=new LinkedList[tableSize];
        intializeHashTable();
    }

    private void intializeHashTable(){
        for (int i=0; i<tableSize;  i++){
            hashTable[i]= new LinkedList<>();
        }
    }


    private int getHashCode(K key){
        int hashcode = Objects.hash(key);
        hashcode = (Math.abs(hashcode))%tableSize;
        return hashcode;
    }

    private int searchKeyInList(K key, int hashcode){
        LinkedList<Node> list = hashTable[hashcode];
        for (int index = 0; index<list.size(); index++){
            if(list.get(index).key.equals(key)){
                return index;
            }
        }
        return -1;
    }

    private void reHash(){
        LinkedList<Node> oldTable[]= hashTable;
        tableSize = 2*tableSize;
        elements=0;
        hashTable = new LinkedList[tableSize];
        intializeHashTable();
        for (LinkedList<Node> list: oldTable){
            for (Node node : list){
                put(node.key,node.value);
            }
        }
    }

    // put
    public void put(K key, V value){
        // find the hashcode using hash function
        int hashcode = getHashCode(key);
        int index = searchKeyInList(key,hashcode);
        Node node = new Node(key,value);
        if(index==-1){
            // insertion head at the head of the linkedList
            hashTable[hashcode].add(0,node);
            elements++;
        }else {
            // agr value present hai to update kr do
            hashTable[hashcode].get(index).value=value;
        }

        // rehashing check
        if(elements/(double)tableSize >=threshold){
            reHash();
        }

    }


    // get
    public V get(K key){
        // find the hashcode using hash function
        int hashcode = getHashCode(key);
        int index = searchKeyInList(key,hashcode);
        if(index==-1){
            return null;
        }else {
           return hashTable[hashcode].get(index).value;
        }
    }

    // contains key
    public boolean containsKey(K key){
        // find the hashcode using hash function
        int hashcode = getHashCode(key);
        int index = searchKeyInList(key,hashcode);
        if(index==-1){
            return false;
        }else {
            return true;
        }
    }

    // contains value
    public boolean containsValue(V value){
        for (int i =0; i<tableSize; i++){
            for (Node node : hashTable[i]){
                if(node.value.equals(value)){
                    return true;
                }
            }
        }
        return false;
    }

    // remove
    public V remove(K key){
        // find the hashcode using hash function
        int hashcode = getHashCode(key);
        int index = searchKeyInList(key,hashcode);
        if(index==-1){
            return null;
        }else {
            V value =  hashTable[hashcode].get(index).value;
            hashTable[hashcode].remove(index);
            elements--;
            return value;
        }
    }

    // empty
    public boolean isEmpty(){
        return (elements==0);
    }

    // size
    public int size(){
        return elements;
    }

    // iterate
    public void iterate(){
        for (int i =0; i<tableSize; i++){
            for (Node node : hashTable[i]){
                System.out.println(node);
            }
        }
    }
}

 





